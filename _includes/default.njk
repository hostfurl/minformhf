{% extends 'blades/html.njk' %}

{% set content_for_header %}
  {% if not site.nohtmx -%}
    <script src="https://cdn.jsdelivr.net/npm/htmx.org@2.0.8/dist/htmx.min.js" defer></script>
    {% if site.corsprod or not site.prod -%}
    <meta name="htmx-config" content='{"selfRequestsOnly": false}'>
    {%- endif %}
  {%- endif %}
<style>
  a[role="button"] {text-align: start; border-width: 1px 0 0 1px; margin: 0.9rem 0 0 -1rem; }
</style>
{% endset %}

{% block body %}
  {%- set nav_pages = collections.all | eleventyNavigation | dataNavigation %}
  {%- renderFile '_includes/nav.liquid', nav_pages  %}
  <main class="container breakout-all">
      {{ content | safe }}
  </main>
  <footer>
    <hr />
    {{ site.footer | renderContent('njk,md', site) | safe }}
  </footer>
{% endblock %}
