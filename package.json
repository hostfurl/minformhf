{
  "name": "Minformhf",
  "version": "0.5.3",
  "description": "Website template starter with markdown and minimalist forms for Hostfurl",
  "private": true,
  "type": "module",
  "workspaces": [
    "do"
  ],
  "scripts": {
    "do": "ELTY_OPTIONS=--input=./content npm -w do run",
    "start": "npm run do -- start:with-tw",
    "stage": "npm run do -- stage",
    "build": "npm run do -- build",
    "dlbaseblog": "curl -L https://github.com/11ty/eleventy-base-blog/tarball/main | tar -xz --strip-components=2 --wildcards -C ./content '*/content/blog/*.md' '*/content/blog/*.png' && sed -i 's/\\.md//g;s/blog\\/third/\\/blog\\/third/' ./content/blog/secondpost.md",
    "upload": "export $(cat .env | sed '/^ *#/d' | xargs) && [ -z \"$REMOTE_DEST\" ] && echo '$REMOTE_DEST' not in .env, see .env.sample for example || rsync -avzr --delete _site/ $REMOTE_DEST"
  },
  "author": "John Heenan and others",
  "license": "MIT",
  "devDependencies": {
    "dotenv": "^17.4.2",
    "prettier-plugin-jinja-template": "^2.2.0",
    "serve": "^14.2.6"
  },
  "dependencies": {
    "@11ty/eleventy": "4.0.0-alpha.7",
    "@11ty/eleventy-img": "^6.0.4",
    "@anyblades/eleventy-blades-base": "^0.4.8",
    "date-fns": "^4.4.0"
  }
}
